<UserControl x:Class="Aml.BOM.Import.UI.Views.NewMakeItemsView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
mc:Ignorable="d" 
d:DesignHeight="600" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Refresh" 
                   Command="{Binding RefreshCommand}"
                   Style="{StaticResource PrimaryButtonStyle}"
                   Margin="0,0,10,0"/>
            <Button Content="Copy From Item" 
                   Command="{Binding CopyFromItemCommand}"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Margin="0,0,10,0"/>
            <Button Content="Clear All" 
                   Command="{Binding ClearAllCommand}"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Margin="0,0,10,0"/>
            <Button Content="Integrate" 
                   Command="{Binding IntegrateItemsCommand}"
                   Background="#4CAF50"
                   Foreground="White"
                   Padding="15,8"
                   BorderThickness="0"
                   Cursor="Hand"/>
        </StackPanel>

        <!-- Statistics Panel -->
        <Border Grid.Row="1" 
                Background="{StaticResource PrimaryBackgroundBrush}" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="5" 
                Padding="15" 
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Items -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Total Items" 
                              FontSize="12" 
                              FontWeight="SemiBold" 
                              Foreground="{StaticResource SecondaryTextBrush}" 
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalItems}" 
                              FontSize="28" 
                              FontWeight="Bold" 
                              Foreground="{StaticResource PrimaryTextBrush}" 
                              HorizontalAlignment="Center" 
                              Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Edited Items -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Edited Items" 
                              FontSize="12" 
                              FontWeight="SemiBold" 
                              Foreground="{StaticResource SecondaryTextBrush}" 
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding EditedItems}" 
                              FontSize="28" 
                              FontWeight="Bold" 
                              Foreground="#FF9800" 
                              HorizontalAlignment="Center" 
                              Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Ready for Integration -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Ready to Integrate" 
                              FontSize="12" 
                              FontWeight="SemiBold" 
                              Foreground="{StaticResource SecondaryTextBrush}" 
                              HorizontalAlignment="Center" 
                              TextWrapping="Wrap" 
                              TextAlignment="Center"/>
                    <TextBlock Text="{Binding ReadyForIntegration}" 
                              FontSize="28" 
                              FontWeight="Bold" 
                              Foreground="#4CAF50" 
                              HorizontalAlignment="Center" 
                              Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Missing Data -->
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="Missing Data" 
                              FontSize="12" 
                              FontWeight="SemiBold" 
                              Foreground="{StaticResource SecondaryTextBrush}" 
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding MissingDataItems}" 
                              FontSize="28" 
                              FontWeight="Bold" 
                              Foreground="#F44336" 
                              HorizontalAlignment="Center" 
                              Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter Panel -->
        <Expander Grid.Row="2" 
                 IsExpanded="True" 
                 Margin="0,0,0,10"
                 Background="{StaticResource SecondaryBackgroundBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 BorderThickness="1">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Filter" 
                                               Width="16" 
                                               Height="16" 
                                               VerticalAlignment="Center" 
                                               Margin="0,0,5,0"/>
                    <TextBlock Text="Filters" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Expander.Header>
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 1 -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                          Text="Import File:" 
                          VerticalAlignment="Center" 
                          Margin="0,0,10,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                        Text="{Binding FilterImportFileName, UpdateSourceTrigger=PropertyChanged}" 
                        Margin="0,0,10,5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" 
                          Text="Date From:" 
                          VerticalAlignment="Center" 
                          Margin="0,0,10,5"/>
                <DatePicker Grid.Row="0" Grid.Column="3" 
                           SelectedDate="{Binding FilterImportDateFrom}" 
                           Margin="0,0,0,5"/>

                <!-- Row 2 -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                          Text="Item Code:" 
                          VerticalAlignment="Center" 
                          Margin="0,0,10,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                        Text="{Binding FilterItemCode, UpdateSourceTrigger=PropertyChanged}" 
                        Margin="0,0,10,5">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Use % and ? wildcards (e.g., ACL5??LS40%)" 
                                                             Foreground="Gray" 
                                                             Margin="5,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock Grid.Row="1" Grid.Column="2" 
                          Text="Date To:" 
                          VerticalAlignment="Center" 
                          Margin="0,0,10,5"/>
                <DatePicker Grid.Row="1" Grid.Column="3" 
                           SelectedDate="{Binding FilterImportDateTo}" 
                           Margin="0,0,0,5"/>

                <!-- Row 3 - Checkboxes and Buttons -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" 
                           Orientation="Horizontal" 
                           Margin="0,10,0,0">
                    <CheckBox IsChecked="{Binding FilterEditedOnly}" 
                             Content="Edited Only" 
                             Margin="0,0,20,0"/>
                    <CheckBox IsChecked="{Binding FilterMissingDataOnly}" 
                             Content="Missing Data" 
                             Margin="0,0,20,0"/>
                    <CheckBox IsChecked="{Binding ShowIntegratedItems}" 
                             Content="Show Integrated" 
                             Margin="0,0,20,0"/>
                    
                    <Button Content="Apply Filters" 
                           Command="{Binding ApplyFiltersCommand}"
                           Style="{StaticResource PrimaryButtonStyle}"
                           Margin="0,0,10,0"/>
                    <Button Content="Clear Filters" 
                           Command="{Binding ClearFiltersCommand}"
                           Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Expander>

        <!-- Make Items DataGrid -->
        <DataGrid x:Name="MakeItemsDataGrid"
                 Grid.Row="3" 
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem}"
                 AutoGenerateColumns="False"
                 CanUserSortColumns="True"
                 CanUserReorderColumns="True"
                 CanUserAddRows="False"
                 CanUserDeleteRows="False"
                 SelectionMode="Single"
                 GridLinesVisibility="All"
                 AlternatingRowBackground="#F5F5F5"
                 IsReadOnly="False"
                 CellEditEnding="DataGrid_CellEditEnding"
                 MouseRightButtonDown="DataGrid_MouseRightButtonDown">
            
            <DataGrid.Columns>
                <!-- System Fields (Read-Only) -->
                <DataGridTextColumn Header="Import File Name" 
                                   Binding="{Binding ImportFileName}" 
                                   Width="200"
                                   IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Background" Value="#EEEEEE"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Import Date" 
                                   Binding="{Binding ImportFileDate, StringFormat='yyyy-MM-dd HH:mm'}" 
                                   Width="140"
                                   IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Background" Value="#EEEEEE"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Item Code" 
                                   Binding="{Binding ItemCode}" 
                                   Width="150"
                                   IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Background" Value="#EEEEEE"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Editable Fields -->
                <DataGridTextColumn Header="Item Description" 
                                   Binding="{Binding ItemDescription, UpdateSourceTrigger=LostFocus}" 
                                   Width="250"
                                   IsReadOnly="False"/>

                <DataGridTextColumn Header="Product Line" 
                                   Binding="{Binding ProductLine, UpdateSourceTrigger=LostFocus}" 
                                   Width="120"
                                   IsReadOnly="False">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Product Type" 
                                   Binding="{Binding ProductType, UpdateSourceTrigger=LostFocus}" 
                                   Width="100"
                                   IsReadOnly="False"/>

                <DataGridTextColumn Header="Procurement" 
                                   Binding="{Binding Procurement, UpdateSourceTrigger=LostFocus}" 
                                   Width="100"
                                   IsReadOnly="False"/>

                <DataGridTextColumn Header="Standard UOM" 
                                   Binding="{Binding StandardUnitOfMeasure, UpdateSourceTrigger=LostFocus}" 
                                   Width="110"
                                   IsReadOnly="False"/>

                <DataGridTextColumn Header="Sub Product Family" 
                                   Binding="{Binding SubProductFamily, UpdateSourceTrigger=LostFocus}" 
                                   Width="150"
                                   IsReadOnly="False"/>

                <DataGridCheckBoxColumn Header="Staged" 
                                       Binding="{Binding StagedItem, UpdateSourceTrigger=PropertyChanged}" 
                                       Width="70"
                                       IsReadOnly="False"/>

                <DataGridCheckBoxColumn Header="Coated" 
                                       Binding="{Binding Coated, UpdateSourceTrigger=PropertyChanged}" 
                                       Width="70"
                                       IsReadOnly="False"/>

                <DataGridCheckBoxColumn Header="Golden Std" 
                                       Binding="{Binding GoldenStandard, UpdateSourceTrigger=PropertyChanged}" 
                                       Width="90"
                                       IsReadOnly="False"/>

                <!-- Status Indicator -->
                <DataGridTemplateColumn Header="Status" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="5,2" CornerRadius="3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsIntegrated}" Value="True">
                                                <Setter Property="Background" Value="#C8E6C9"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsEdited}" Value="True">
                                                <Setter Property="Background" Value="#FFE082"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="New"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIntegrated}" Value="True">
                                                    <Setter Property="Text" Value="? Done"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEdited}" Value="True">
                                                    <Setter Property="Text" Value="? Edited"/>
                                                    <Setter Property="Foreground" Value="#F57C00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <!-- Row Style for highlighting -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="IsEnabled" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsIntegrated}" Value="True">
                            <Setter Property="Foreground" Value="#757575"/>
                            <Setter Property="FontStyle" Value="Italic"/>
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E3F2FD"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Status Bar -->
        <Border Grid.Row="4" 
                Background="{StaticResource SecondaryBackgroundBrush}" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,1,0,0" 
                Padding="10,5">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" 
                          FontSize="12" 
                          Foreground="{StaticResource SecondaryTextBrush}"
                          HorizontalAlignment="Left"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <iconPacks:PackIconMaterial Kind="Lightbulb" 
                                               Width="14" 
                                               Height="14" 
                                               VerticalAlignment="Center" 
                                               Margin="0,0,5,0"
                                               Foreground="#FFC107"/>
                    <TextBlock Text="Tip: Use % for multiple chars, ? for single char in Item Code filter" 
                              FontSize="11" 
                              Foreground="{StaticResource SecondaryTextBrush}"
                              FontStyle="Italic"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5" 
               Background="#80000000" 
               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading..." 
                          FontSize="20" 
                          Foreground="White" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,10"/>
                <ProgressBar IsIndeterminate="True" 
                            Width="200" 
                            Height="10"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
