<Window x:Class="Aml.BOM.Import.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About AML BOM Import"
        Height="450" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource PrimaryBackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#2C3E50" 
                Padding="20">
            <StackPanel HorizontalAlignment="Center">
                <Viewbox Width="64" Height="64" Margin="0,0,0,15">
                    <Canvas Width="24" Height="24">
                        <Path Fill="White" 
                              Data="M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3M7,7H17V5H19V19H5V5H7V7M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,11A1,1 0 0,1 13,12A1,1 0 0,1 12,13A1,1 0 0,1 11,12A1,1 0 0,1 12,11Z"/>
                    </Canvas>
                </Viewbox>
                
                <TextBlock Text="AML BOM Import" 
                          FontSize="28" 
                          FontWeight="Bold" 
                          Foreground="White" 
                          HorizontalAlignment="Center"/>
                
                <TextBlock x:Name="VersionTextBlock"
                          FontSize="14" 
                          Foreground="#ECF0F1" 
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" 
                     VerticalScrollBarVisibility="Auto"
                     Padding="30,20">
            <StackPanel>
                <TextBlock Text="Description" 
                          FontSize="16" 
                          FontWeight="SemiBold" 
                          Foreground="{StaticResource PrimaryTextBrush}"
                          Margin="0,0,0,10"/>
                
                <TextBlock TextWrapping="Wrap" 
                          Foreground="{StaticResource SecondaryTextBrush}"
                          Margin="0,0,0,20">
                    A comprehensive Bill of Materials (BOM) import and integration tool for Sage 100. 
                    Import BOMs from Excel files, validate components, manage new items, and seamlessly 
                    integrate with Sage 100 using COM automation.
                </TextBlock>

                <TextBlock Text="Key Features" 
                          FontSize="16" 
                          FontWeight="SemiBold" 
                          Foreground="{StaticResource PrimaryTextBrush}"
                          Margin="0,0,0,10"/>
                
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3" Text="- Import BOMs from Excel files"/>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3" Text="- Automatic validation against Sage 100 items"/>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3" Text="- Manage new make and buy items"/>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3" Text="- Duplicate detection and handling"/>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3" Text="- Direct integration with Sage 100 via COM"/>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3" Text="- Comprehensive logging and error tracking"/>
                </StackPanel>

                <TextBlock Text="System Information" 
                          FontSize="16" 
                          FontWeight="SemiBold" 
                          Foreground="{StaticResource PrimaryTextBrush}"
                          Margin="0,0,0,10"/>
                
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" 
                              Text=".NET Version:" 
                              Foreground="{StaticResource SecondaryTextBrush}"
                              Margin="0,3,10,3"/>
                    <TextBlock x:Name="DotNetVersionTextBlock"
                              Grid.Row="0" Grid.Column="1" 
                              Foreground="{StaticResource PrimaryTextBrush}"
                              Margin="0,3"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" 
                              Text="OS Version:" 
                              Foreground="{StaticResource SecondaryTextBrush}"
                              Margin="0,3,10,3"/>
                    <TextBlock x:Name="OSVersionTextBlock"
                              Grid.Row="1" Grid.Column="1" 
                              Foreground="{StaticResource PrimaryTextBrush}"
                              Margin="0,3"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" 
                              Text="Build Date:" 
                              Foreground="{StaticResource SecondaryTextBrush}"
                              Margin="0,3,10,3"/>
                    <TextBlock x:Name="BuildDateTextBlock"
                              Grid.Row="2" Grid.Column="1" 
                              Foreground="{StaticResource PrimaryTextBrush}"
                              Margin="0,3"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" 
                              Text="Copyright:" 
                              Foreground="{StaticResource SecondaryTextBrush}"
                              Margin="0,3,10,3"/>
                    <TextBlock x:Name="CopyrightTextBlock"
                              Grid.Row="3" Grid.Column="1" 
                              Foreground="{StaticResource PrimaryTextBrush}"
                              Margin="0,3"/>
                </Grid>

                <TextBlock Text="License" 
                          FontSize="16" 
                          FontWeight="SemiBold" 
                          Foreground="{StaticResource PrimaryTextBrush}"
                          Margin="0,0,0,10"/>
                
                <TextBlock TextWrapping="Wrap" 
                          Foreground="{StaticResource SecondaryTextBrush}">
                    This software is proprietary and confidential. 
                    Unauthorized copying, distribution, or use is strictly prohibited.
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,1,0,0"
                Padding="20">
            <StackPanel>
                <Button Content="Close" 
                       Click="CloseButton_Click"
                       Style="{StaticResource PrimaryButtonStyle}"
                       HorizontalAlignment="Center"
                       MinWidth="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
